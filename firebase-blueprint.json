{
  "entities": {
    "Cd": {
      "title": "Centro de Distribuição",
      "description": "Dados dos CDs",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "ativo": { "type": "boolean" }
      }
    },
    "AgendaDia": {
      "title": "Agenda Diária",
      "description": "Programação diária dos analistas",
      "type": "object",
      "properties": {
        "usuarioNome": { "type": "string" },
        "data": { "type": "string" },
        "cd": { "type": "string" },
        "atividade": { "type": "string" },
        "obs": { "type": "string" },
        "yyyyMM": { "type": "string" },
        "uidKey": { "type": "string" }
      }
    },
    "Usuario": {
      "title": "Usuário",
      "description": "Dados dos usuários do sistema",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "perfil": { "type": "string" },
        "ativo": { "type": "boolean" }
      }
    },
    "Chamado": {
      "title": "Chamado",
      "description": "Solicitações de suporte ou chamados",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "descricao": { "type": "string" },
        "status": { "type": "string" },
        "criadoEm": { "type": "string", "format": "date-time" }
      }
    },
    "Mensagem": {
      "title": "Mensagem",
      "description": "Mensagens dentro de um chamado",
      "type": "object",
      "properties": {
        "texto": { "type": "string" },
        "autor": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "cds": { "schema": "Cd", "description": "Coleção de CDs" },
    "agenda_dias": { "schema": "AgendaDia", "description": "Agendas diárias" },
    "usuarios": { "schema": "Usuario", "description": "Lista de usuários" },
    "chamados": { "schema": "Chamado", "description": "Chamados" },
    "chamados/{chamadoId}/mensagens": { "schema": "Mensagem", "description": "Mensagens de chamados" },
    "rota_visitas": { "schema": "RotaVisita", "description": "Rotas de visitas" },
    "treinamentos_realizados": { "schema": "TreinamentoRealizado", "description": "Treinamentos efetuados" },
    "apuracoes_treinamentos": { "schema": "Apuracao", "description": "Apurações" },
    "rps_atividades": { "schema": "RpsAtividade", "description": "RPS Atividades" },
    "biblioteca_treinamentos": { "schema": "Biblioteca", "description": "Biblioteca" },
    "acessos": { "schema": "Acesso", "description": "Logs de acesso" }
  }
}
