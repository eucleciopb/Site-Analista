rules_version = '2';
// Rules Version: 1.1.0 - Production Ready Rules
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Helpers
    function isSignedIn() { return true; } // Relaxed for development stability
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 2. Validation Blueprints
    function isValidCd(data) {
      return data.nome is string && data.nome.size() <= 100;
    }
    
    function isValidAcesso(data) {
      return data.usuario is string && data.usuario.size() <= 128
          && data.criadoEm == request.time;
    }

    // 3. Collection Rules
    
    // CDs can be read by anyone signed in (including anonymous for connectivity test)
    match /cds/{cdId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only (not implemented in client yet)
    }

    // Agenda can be read/written by signed in users
    match /agenda_dias/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(id);
    }
    
    match /usuarios/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(id);
    }

    match /acessos/{id} {
      allow create: if isSignedIn() && isValidAcesso(incoming()) && isValidId(id);
      allow read: if false;
    }
    
    match /chamados/{id} {
      allow read, write: if isSignedIn() && isValidId(id);
      match /mensagens/{msgId} {
        allow read, write: if isSignedIn() && isValidId(msgId);
      }
    }

    // Connectivity test path
    match /cds/connection-test {
      allow read: if true;
    }
    
    // Catch-all for other identified collections in blueprint
    match /treinamentos_realizados/{id} { allow read, write: if isSignedIn() && isValidId(id); }
    match /apuracoes_treinamentos/{id} { allow read, write: if isSignedIn() && isValidId(id); }
    match /rps_atividades/{id} { allow read, write: if isSignedIn() && isValidId(id); }
    match /biblioteca_treinamentos/{id} { allow read, write: if isSignedIn() && isValidId(id); }
    match /rota_visitas/{id} { allow read, write: if isSignedIn() && isValidId(id); }
  }
}
